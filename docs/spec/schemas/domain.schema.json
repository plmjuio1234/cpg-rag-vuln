{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cpg_gnn/domain.schema.json",
  "title": "DDD Domain Spec",
  "type": "object",
  "required": ["specVersion", "document", "boundedContexts", "invariants"],
  "properties": {
    "specVersion": { "type": "string" },
    "document": {
      "type": "object",
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "language": { "type": "string" }
      },
      "additionalProperties": true
    },
    "boundedContexts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "purpose"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "purpose": { "type": "string" },
          "owners": {
            "type": "array",
            "items": { "type": "string" }
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "integration": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "aggregates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "contextRef", "name", "rootEntity"],
        "properties": {
          "id": { "type": "string" },
          "contextRef": { "type": "string" },
          "name": { "type": "string" },
          "rootEntity": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "scopeRef", "rule", "violationError"],
        "properties": {
          "id": { "type": "string" },
          "scopeRef": { "type": "string" },
          "rule": { "type": "string" },
          "violationError": {
            "type": "object",
            "required": ["code", "message"],
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
