{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cpg_gnn/spec-meta.schema.json",
  "title": "Spec Meta",
  "type": "object",
  "required": ["specVersion", "document"],
  "properties": {
    "specVersion": {
      "type": "string"
    },
    "document": {
      "type": "object",
      "required": ["id", "title"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "language": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
